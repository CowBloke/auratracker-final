# Backend Environment Configuration
# Copy this file to .env for local development

# Database connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aura_tracker"

# JWT configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Redis connection string
REDIS_URL="redis://localhost:6379"

# Server configuration
PORT=3000
NODE_ENV="development"

# CORS origin for frontend
# Development: http://localhost:5173
# Production: https://auratracker.xyz
CORS_ORIGIN="http://localhost:5173"

# Admin email for admin privileges
ADMIN_EMAIL="admin@auratracker.com"

# SMTP configuration for email notifications (optional)
# If not set, emails are skipped and only in-app notifications are sent
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="AuraTracker <noreply@auratracker.com>"
