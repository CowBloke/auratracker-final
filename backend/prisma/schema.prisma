generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User Model
model User {
  id                 String    @id @default(uuid())
  username           String    @unique
  firstName          String? // Real first name
  email              String    @unique
  passwordHash       String
  aura               BigInt    @default(0)
  money              Int       @default(1000)
  auraCoinBalance    Float     @default(0) // Aura Coin balance for trading game
  solarisBalance     Float     @default(0) // Solaris balance for trading game
  zenithBalance      Float     @default(0) // Zenith balance for trading game
  riftBalance        Float     @default(0) // Rift balance for trading game
  isAdmin            Boolean   @default(false)
  isChatMuted        Boolean   @default(false)
  isApproved         Boolean   @default(false) // Account must be approved by admin before login
  dailyAuraGiven     Int       @default(0) // Aura given today
  dailyAuraLimit     Int       @default(50) // Personal daily aura limit (default 50)
  lastDailyReset     DateTime  @default(now()) // When daily allowance was last reset
  dailyPassStreak    Int       @default(0) // Current daily pass streak
  lastDailyPassClaim DateTime? // Last date when daily pass reward was claimed
  usernameColor      String? // Custom username color for chat (hex)
  profilePicture     String? // Custom profile picture URL for chat
  bio                String? // User bio/description
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  ownedItems            UserItem[]
  sentTransfers         Transfer[]             @relation("SentTransfers")
  receivedTransfers     Transfer[]             @relation("ReceivedTransfers")
  gameStats             GameStats[]
  partyMemberships      PartyMember[]
  sentMessages          ChatMessage[]
  chatReactions         ChatReaction[]
  clashBase             ClashBase?
  attacksMade           Attack[]               @relation("Attacker")
  attacksReceived       Attack[]               @relation("Defender")
  auraCoinTransactions  AuraCoinTransaction[]
  auraCoinPositions     AuraCoinPosition[]
  solarisTransactions   SolarisTransaction[]
  zenithTransactions    ZenithTransaction[]
  riftTransactions      RiftTransaction[]
  bugReports            BugReport[]
  suggestions           Suggestion[]
  suggestionVotes       SuggestionVote[]
  suggestionComments    SuggestionComment[]
  suggestionRatings     SuggestionRating[]
  bombPartyStats        BombPartyStats?
  bansReceived          Ban[]                  @relation("BannedUser")
  bansIssued            Ban[]                  @relation("BanIssuer")
  userBadges            UserBadge[]
  ownedClans            Clan[]                 @relation("ClanOwner")
  clanMemberships       ClanMember[]
  clanJoinRequests      ClanJoinRequest[]
  polymarketSuggestions PolymarketSuggestion[]
  polymarketBets        PolymarketBet[]
  createdUpdatePopups   UpdatePopup[]           @relation("UpdatePopupCreator")
  updatePopupViews      UserUpdatePopupView[]


  // Daily Quests relations
  dailyQuests         UserDailyQuest[]

  // Gift System
  sentGifts           Gift[]                 @relation("SentGifts")
  receivedGifts       Gift[]                 @relation("ReceivedGifts")
  wordleAttempts      WordleAttempt[]
  dailyRacerRuns      DailyRacerRun[]

  @@index([aura])
  @@index([money])
}

// Badge System
model Badge {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  badgeId    String
  assignedAt DateTime @default(now())
  isSelected Boolean  @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// Item Model
// type: "CONSUMABLE" | "COSMETIC" | "UPGRADE"
model Item {
  id          String    @id @default(uuid())
  name        String
  description String
  type        String // CONSUMABLE, COSMETIC, or UPGRADE
  price       Int
  imageUrl    String?
  effect      String? // JSON string describing the effect
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  userItems UserItem[]
}

// User Inventory
model UserItem {
  id         String   @id @default(uuid())
  userId     String
  itemId     String
  quantity   Int      @default(1)
  acquiredAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  item          Item           @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

// Transfer/Trade Model
model Transfer {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  auraAmount  Int      @default(0)
  moneyAmount Int      @default(0)
  isGift      Boolean  @default(false) // True if from daily gift allowance
  message     String? // Optional message (max 20 words)
  createdAt   DateTime @default(now())

  sender   User @relation("SentTransfers", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedTransfers", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
}

// Game Statistics
model GameStats {
  id          String @id @default(uuid())
  userId      String
  gameType    String // "doodle_jump", "casino"
  wins        Int    @default(0)
  losses      Int    @default(0)
  highScore   Int    @default(0)
  totalPlayed Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
}

// Daily Wordle puzzle and user attempts
model WordlePuzzle {
  id         String   @id @default(uuid())
  puzzleDate DateTime @unique
  word       String
  createdAt  DateTime @default(now())

  attempts WordleAttempt[]

  @@index([puzzleDate])
}

model WordleAttempt {
  id            String   @id @default(uuid())
  puzzleId      String
  userId        String
  guessesJson   String   @default("[]")
  isCompleted   Boolean  @default(false)
  solved        Boolean  @default(false)
  guessCount    Int?
  completedAt   DateTime?
  firstPlayedAt DateTime @default(now())
  updatedAt     DateTime @updatedAt

  puzzle WordlePuzzle @relation(fields: [puzzleId], references: [id], onDelete: Cascade)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([puzzleId, userId])
  @@index([puzzleId, solved, guessCount])
  @@index([userId, updatedAt])
}

model DailyRacerRun {
  id        String   @id @default(uuid())
  userId    String
  trackDate DateTime
  lapTimeMs Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trackDate, lapTimeMs])
  @@index([trackDate, userId])
  @@index([userId, createdAt])
}

// Party System
model Party {
  id           String   @id @default(uuid())
  name         String?
  isPublic     Boolean  @default(false)
  maxSize      Int      @default(8)
  createdAt    DateTime @default(now())
  lastActivity DateTime @default(now())

  members PartyMember[]
}

model PartyMember {
  id       String   @id @default(uuid())
  partyId  String
  userId   String
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@unique([userId]) // User can only be in one party at a time
}

// Clan System
model Clan {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  isPublic    Boolean  @default(true)
  maxMembers  Int      @default(5)
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User              @relation("ClanOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members      ClanMember[]
  joinRequests ClanJoinRequest[]

  @@index([isPublic])
  @@index([createdAt])
}

model ClanMember {
  id       String   @id @default(uuid())
  clanId   String
  userId   String
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@unique([userId])
  @@index([clanId])
}

model ClanJoinRequest {
  id        String   @id @default(uuid())
  clanId    String
  userId    String
  createdAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@index([clanId])
  @@index([userId])
}

// Chat Messages
model ChatMessage {
  id        String    @id @default(uuid())
  userId    String
  message   String
  replyToId String?
  pinned    Boolean   @default(false)
  pinnedAt  DateTime?
  createdAt DateTime  @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo   ChatMessage?   @relation("ChatMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[]  @relation("ChatMessageReply")
  reactions ChatReaction[]

  @@index([createdAt])
}

model ChatReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

// Season System
model Season {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  @@index([isActive])
}

// Clash of Clans Base
model ClashBase {
  id             String    @id @default(uuid())
  userId         String    @unique
  baseLayout     String // JSON string storing building positions/levels
  defenseRating  Int       @default(100)
  trophies       Int       @default(0)
  lastAttackedAt DateTime?
  shieldUntil    DateTime?
  attackCooldown DateTime? // When user can attack again
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([defenseRating])
  @@index([trophies])
}

// Attack Log
model Attack {
  id           String   @id @default(uuid())
  attackerId   String
  defenderId   String
  success      Boolean
  starsEarned  Int      @default(0) // 0-3 stars
  destruction  Int      @default(0) // Percentage 0-100
  auraTaken    Int      @default(0)
  moneyTaken   Int      @default(0)
  trophiesWon  Int      @default(0)
  trophiesLost Int      @default(0)
  replayData   String? // JSON string for replay
  attackedAt   DateTime @default(now())

  attacker User @relation("Attacker", fields: [attackerId], references: [id], onDelete: Cascade)
  defender User @relation("Defender", fields: [defenderId], references: [id], onDelete: Cascade)

  @@index([attackerId])
  @@index([defenderId])
  @@index([attackedAt])
}

// Aura Coin Price History
model AuraCoinPrice {
  id        String   @id @default(uuid())
  price     Float
  volume    Float    @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Aura Coin Transaction
model AuraCoinTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String // "BUY" or "SELL"
  coinAmount  Float
  moneyAmount Int
  price       Float
  fee         Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Aura Coin Position (Leveraged Trading)
model AuraCoinPosition {
  id           String    @id @default(uuid())
  userId       String
  type         String // "LONG" or "SHORT"
  leverage     Int // 1 to 10
  entryPrice   Float // Price when position was opened
  coinAmount   Float // Notional value in coins
  marginAmount Int // Collateral deposited (money)
  isOpen       Boolean   @default(true)
  closedAt     DateTime?
  exitPrice    Float? // Price when position was closed
  pnl          Int? // Profit/Loss when closed
  liquidated   Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isOpen])
  @@index([createdAt])
}

// Solaris Price History
model SolarisPrice {
  id        String   @id @default(uuid())
  price     Float
  volume    Float    @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Solaris Transaction
model SolarisTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String // "BUY" or "SELL"
  coinAmount  Float
  moneyAmount Int
  price       Float
  fee         Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Zenith Price History
model ZenithPrice {
  id        String   @id @default(uuid())
  price     Float
  volume    Float    @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Zenith Transaction
model ZenithTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String // "BUY" or "SELL"
  coinAmount  Float
  moneyAmount Int
  price       Float
  fee         Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Rift Price History
model RiftPrice {
  id        String   @id @default(uuid())
  price     Float
  volume    Float    @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Rift Transaction
model RiftTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String // "BUY" or "SELL"
  coinAmount  Float
  moneyAmount Int
  price       Float
  fee         Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Bug Report
model BugReport {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String
  status      String    @default("PENDING") // PENDING, DONE
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

// Suggestion
model Suggestion {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String
  imageUrl    String?
  status      String    @default("PENDING") // PENDING, DONE
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes    SuggestionVote[]
  comments SuggestionComment[]
  ratings  SuggestionRating[]

  @@index([status])
  @@index([createdAt])
}

// Suggestion Comment
model SuggestionComment {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  content      String
  createdAt    DateTime @default(now())

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([suggestionId])
  @@index([createdAt])
}

// Suggestion Vote
model SuggestionVote {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  value        Int // 1 for upvote, -1 for downvote
  createdAt    DateTime @default(now())

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

// Suggestion Rating
model SuggestionRating {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  rating       Int // 1-10
  createdAt    DateTime @default(now())

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

// Bomb Party Prompts (precomputed)
model BombPartyPrompt {
  id         String @id @default(uuid())
  prompt     String @unique // e.g., "TH", "ING", "QU"
  wordCount  Int // precomputed count of valid words
  length     Int    @default(2) // prompt length (2 or 3)

  @@index([wordCount])
  @@index([length])
  @@index([length, wordCount])
}

// Game Settings (configurable values for admin panel)
model GameSettings {
  id        String   @id @default(uuid())
  key       String   @unique // e.g., "bombparty_wpp_easy", "bombparty_wpp_medium"
  value     String // stored as string, parsed as needed
  updatedAt DateTime @updatedAt
}

// Bomb Party Player Stats
model BombPartyStats {
  id          String  @id @default(uuid())
  userId      String  @unique
  wins        Int     @default(0)
  losses      Int     @default(0)
  totalPlayed Int     @default(0)
  wordsTyped  Int     @default(0)
  longestWord String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Ban System
model Ban {
  id        String    @id @default(uuid())
  userId    String
  bannedBy  String // Admin user ID who issued the ban
  reason    String
  type      String // "TEMPORARY" or "PERMANENT"
  expiresAt DateTime? // Null for permanent bans
  createdAt DateTime  @default(now())
  isActive  Boolean   @default(true)

  user  User @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  admin User @relation("BanIssuer", fields: [bannedBy], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
}

// Activity Log
model Log {
  id         String   @id @default(uuid())
  type       String // AUTH, CHAT, GAME, ECONOMY, PARTY, SUGGESTION, MARKETPLACE, ADMIN, BAN
  action     String // login, logout, register, message, game_complete, transfer, etc.
  userId     String? // User who performed the action (nullable for system events)
  username   String? // Cached username for display
  targetId   String? // Target user/entity ID (for transfers, bans, etc.)
  targetName String? // Cached target name for display
  details    String? // JSON string with additional details
  metadata   String? // JSON string with extra metadata (amounts, scores, etc.)
  ipAddress  String? // IP address if available
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// Polymarket System
model PolymarketSuggestion {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String
  imageUrl    String?
  eventDate   DateTime? // Date de réalisation de l’événement
  suggestedYesOdds Float? // Cote suggérée pour "Oui"
  suggestedNoOdds  Float? // Cote suggérée pour "Non"
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime  @default(now())
  reviewedAt  DateTime?
  reviewedBy  String? // Admin ID who reviewed

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event PolymarketEvent? // If approved and converted to event

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model PolymarketEvent {
  id           String    @id @default(uuid())
  suggestionId String?   @unique // If created from suggestion
  title        String
  description  String
  imageUrl     String?
  eventDate    DateTime // Date de réalisation de l'événement
  yesOdds      Float // Cote pour "Oui" (ex: 1.5 = mise * 1.5 si gagnant)
  noOdds       Float // Cote pour "Non" (ex: 2.0 = mise * 2.0 si gagnant)
  status       String    @default("OPEN") // OPEN, CLOSED, RESOLVED
  resolution   String? // "YES" or "NO" when resolved
  resolvedAt   DateTime?
  resolvedBy   String? // Admin ID who resolved
  createdAt    DateTime  @default(now())
  closedAt     DateTime? // When betting closed (before event date)

  suggestion PolymarketSuggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)
  bets       PolymarketBet[]

  @@index([status])
  @@index([eventDate])
  @@index([createdAt])
}

model PolymarketBet {
  id         String   @id @default(uuid())
  userId     String
  eventId    String
  prediction String // "YES" or "NO"
  amount     Int // Mise en money
  payout     BigInt? // Gains calculés après résolution (null si perdu)
  createdAt  DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  event PolymarketEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId]) // Un seul pari par utilisateur par événement
  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
}


// ============================================
// DAILY QUESTS SYSTEM
// ============================================

// Daily Quest Template (10 quests generated each day)
model DailyQuest {
  id          String   @id @default(uuid())
  questType   String // "JOIN_PARTIES", "DOODLE_JUMP_SCORE", "GAME_2048_SCORE", "FLAPPY_BIRD_SCORE", "BOMB_PARTY_PLAYS", "POKER_PLAYS", "PETIT_BAC_PLAYS", "BATTLESHIP_PLAYS", "WIN_GAMES", "PLAY_GAMES"
  title       String
  description String
  targetValue Int // Target value (e.g., 3 parties, 1000 score)
  moneyReward Int // Money reward
  auraReward  Int // Aura reward
  questDate   DateTime @default(now()) // Date of the quest (used to group quests by day)
  createdAt   DateTime @default(now())

  userSelections UserDailyQuest[]

  @@index([questDate])
  @@index([questType])
}

// User's selected daily quests (max 3 per day)
model UserDailyQuest {
  id          String   @id @default(uuid())
  userId      String
  questId     String
  questDate   DateTime // Date of the quest
  selectedAt  DateTime @default(now())
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  isClaimed   Boolean  @default(false)
  claimedAt   DateTime?

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest DailyQuest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  progress UserQuestProgress?

  @@unique([userId, questId, questDate])
  @@index([userId])
  @@index([questId])
  @@index([questDate])
  @@index([isCompleted])
}

// User's progress on their selected quests
model UserQuestProgress {
  id              String   @id @default(uuid())
  userQuestId     String   @unique
  currentValue    Int      @default(0) // Current progress value
  lastUpdated     DateTime @default(now())

  userQuest UserDailyQuest @relation(fields: [userQuestId], references: [id], onDelete: Cascade)

  @@index([userQuestId])
}

// ============================================
// GIFT / PRESENT SYSTEM
// ============================================

// Admin-defined gift templates (items that can be included in gifts)
model GiftTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  price       Int      // Cost in money to include this in a gift
  createdAt   DateTime @default(now())

  giftItems GiftItem[]
}

// A gift sent from one user to another
model Gift {
  id          String    @id @default(uuid())
  senderId    String
  receiverId  String
  message     String?   // Custom message from the gifter
  moneyAmount Int       @default(0) // Money included (max 1000)
  auraAmount  Int       @default(0) // Aura included in the gift
  isOpened    Boolean   @default(false)
  openedAt    DateTime?
  createdAt   DateTime  @default(now())

  sender   User       @relation("SentGifts", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User       @relation("ReceivedGifts", fields: [receiverId], references: [id], onDelete: Cascade)
  items    GiftItem[]

  @@index([senderId])
  @@index([receiverId])
  @@index([isOpened])
  @@index([createdAt])
}

// Items included in a gift (references GiftTemplate)
model GiftItem {
  id             String @id @default(uuid())
  giftId         String
  giftTemplateId String

  gift         Gift         @relation(fields: [giftId], references: [id], onDelete: Cascade)
  giftTemplate GiftTemplate @relation(fields: [giftTemplateId], references: [id], onDelete: Cascade)

  @@index([giftId])
  @@index([giftTemplateId])
}

// Online User Snapshot (for activity graphs)
model OnlineSnapshot {
  id        String   @id @default(uuid())
  count     Int      // Number of online users at this moment
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Update Popup System
model UpdatePopup {
  id          String   @id @default(uuid())
  title       String
  summary     String? // Optional short subtitle/summary
  message     String
  imageUrl    String?
  releaseDate DateTime @default(now())
  isPublished Boolean  @default(true)
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User                  @relation("UpdatePopupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  views     UserUpdatePopupView[]

  @@index([isPublished, releaseDate])
  @@index([createdAt])
}

model UserUpdatePopupView {
  id        String   @id @default(uuid())
  userId    String
  popupId   String
  viewedAt  DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  popup UpdatePopup @relation(fields: [popupId], references: [id], onDelete: Cascade)

  @@unique([userId, popupId])
  @@index([userId, viewedAt])
}
