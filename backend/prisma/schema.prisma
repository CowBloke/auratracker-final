generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User Model
model User {
  id                      String    @id @default(uuid())
  username                String    @unique
  firstName               String? // Real first name
  schoolLevel             String? // Seconde, Premiere, Terminale
  classLetter             String? // A-G
  email                   String    @unique
  passwordHash            String
  aura                    BigInt    @default(0)
  money                   Int       @default(1000)
  auraCoinBalance         Float     @default(0) // Aura Coin balance for trading game
  isAdmin                 Boolean   @default(false)
  isSuperAdmin            Boolean   @default(false)
  isChatMuted             Boolean   @default(false)
  isApproved              Boolean   @default(false) // Account must be approved by admin before login
  dailyAuraGiven          Int       @default(0) // Aura given today
  dailyAuraLimit          Int       @default(100) // Personal daily aura limit (default 100)
  lastDailyReset          DateTime  @default(now()) // When daily allowance was last reset
  dailyPassStreak         Int       @default(0) // Current daily pass streak
  lastDailyPassClaim      DateTime? // Last date when daily pass reward was claimed
  usernameColor           String? // Custom username color for chat (hex)
  profilePicture          String? // Custom profile picture URL for chat
  profileBanner           String? // Custom profile banner URL for player profile
  bio                     String? // User bio/description
  motivationMessage       String? // Registration motivation shown to admins before approval
  referralCode            String?   @unique
  referredById            String?
  referredAt              DateTime?
  referralRewardGrantedAt DateTime?
  welcomeInboxSentAt      DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  // Relations
  ownedItems                   UserItem[]
  marketplaceListings          MarketplaceListing[]          @relation("MarketplaceListingSeller")
  sentTransfers                Transfer[]                    @relation("SentTransfers")
  receivedTransfers            Transfer[]                    @relation("ReceivedTransfers")
  gameStats                    GameStats[]
  gameScoreHistory             GameScoreHistory[]
  partyMemberships             PartyMember[]
  partyMessages                PartyMessage[]
  sentMessages                 ChatMessage[]
  chatReactions                ChatReaction[]
  following                    UserFollow[]                  @relation("UserFollowing")
  followers                    UserFollow[]                  @relation("UserFollowers")
  ownedBusinesses              Business[]                    @relation("BusinessOwner")
  businessMemberships          BusinessMember[]
  buyoutOffersPlaced           BusinessBuyoutOffer[]         @relation("BuyoutBidder")
  buyoutOffersReceived         BusinessBuyoutOffer[]         @relation("BusinessBuyoutOwner")
  businessShareholdings        BusinessShareholder[]
  sentShareholderProposals     BusinessShareProposal[]       @relation("BusinessShareProposalInvestor")
  receivedShareholderProposals BusinessShareProposal[]       @relation("BusinessShareProposalOwner")
  sentBusinessTransfers        BusinessTransferTransaction[] @relation("BusinessTransferSender")
  receivedBusinessTransfers    BusinessTransferTransaction[] @relation("BusinessTransferRecipient")
  sentBusinessInvitations      BusinessInvitation[]          @relation("BusinessInvitationSender")
  receivedBusinessInvitations  BusinessInvitation[]          @relation("BusinessInvitationRecipient")
  borrowedBusinessLoans        BusinessLoan[]
  businessInvestments          BusinessInvestment[]
  youSkills                    UserSkill[]
  initiatedRelationships       Relationship[]                @relation("RelationshipInitiatedBy")
  relationshipSideA            Relationship[]                @relation("RelationshipUserA")
  relationshipSideB            Relationship[]                @relation("RelationshipUserB")
  sentMarriageProposals        MarriageProposal[]            @relation("MarriageProposalSender")
  receivedMarriageProposals    MarriageProposal[]            @relation("MarriageProposalRecipient")
  sentDivorceProposals         DivorceProposal[]             @relation("DivorceProposalSender")
  receivedDivorceProposals     DivorceProposal[]             @relation("DivorceProposalRecipient")
  sentAccusations              CheatingAccusation[]          @relation("AccusationAccuser")
  receivedAccusations          CheatingAccusation[]          @relation("AccusationAccused")
  auraCoinTransactions         AuraCoinTransaction[]
  auraCoinPositions            AuraCoinPosition[]
  bugReports                   BugReport[]
  suggestions                  Suggestion[]
  suggestionVotes              SuggestionVote[]
  suggestionComments           SuggestionComment[]
  suggestionRatings            SuggestionRating[]
  bombPartyStats               BombPartyStats?
  bansReceived                 Ban[]                         @relation("BannedUser")
  bansIssued                   Ban[]                         @relation("BanIssuer")
  banAppeals                   BanAppeal[]
  nameChangeRequests           NameChangeRequest[]
  ownedClans                   Clan[]                        @relation("ClanOwner")
  clanMemberships              ClanMember[]
  clanJoinRequests             ClanJoinRequest[]
  clanMessages                 ClanMessage[]
  clanBankContributions        ClanBankContribution[]
  createdClanEvents            ClanEvent[]                   @relation("ClanEventCreator")
  clanEventQuestProgresses     ClanEventQuestProgress[]
  clanEventMiniGameAttempts    ClanEventMiniGameAttempt[]
  clanEventActivities          ClanEventActivity[]
  declaredClanWars             ClanWar[]                     @relation("ClanWarDeclaredBy")
  clanWarAttacks               ClanWarAttack[]
  clanWarFortifications        ClanWarFortification[]
  polymarketSuggestions        PolymarketSuggestion[]
  polymarketBets               PolymarketBet[]
  createdUpdatePopups          UpdatePopup[]                 @relation("UpdatePopupCreator")
  updatePopupViews             UserUpdatePopupView[]

  // Daily Quests relations
  dailyQuests UserDailyQuest[]

  // Gift System
  sentGifts     Gift[] @relation("SentGifts")
  receivedGifts Gift[] @relation("ReceivedGifts")

  // Notifications
  notifications       Notification[]
  dailyRacerRuns      DailyRacerRun[]
  polytrackRecords    PolytrackRecord[]
  goyaveSave          GoyaveSave?
  clashVillage        ClashVillage?
  clashAttacks        ClashBattle[]        @relation("ClashBattleAttacker")
  clashDefenses       ClashBattle[]        @relation("ClashBattleDefender")
  clanWarsWon         ClanWar[]            @relation("ClanWarWinner")
  registrationReviews RegistrationReview[] @relation("RegistrationReviewReviewer")
  clanWarGameLogs     ClanWarGameLog[]
  clanWarNavalShots   ClanWarNavalShot[]

  // Admin Warnings
  warningsReceived AdminWarning[] @relation("WarningsReceived")
  warningsIssued   AdminWarning[] @relation("WarningsIssued")

  // Support Messages
  supportMessages SupportMessage[] @relation("UserSupportMessages")

  // Badge System
  equippedBadge1Id    String?
  equippedBadge2Id    String?
  equippedBadge1      Badge?               @relation("UserEquippedBadge1", fields: [equippedBadge1Id], references: [id], onDelete: SetNull)
  equippedBadge2      Badge?               @relation("UserEquippedBadge2", fields: [equippedBadge2Id], references: [id], onDelete: SetNull)
  earnedBadges        UserBadge[]
  createdBadges       Badge[]              @relation("BadgeCreator")
  customBadgeRequests CustomBadgeRequest[]

  // Overall Ranking System (combines all classements)
  totalScore      Float    @default(0) // Lower score = better player (summary of all rankings)
  overallRank     Int      @default(0) // Their rank in the combined leaderboard (1 = best player)
  lastScoreUpdate DateTime @default(now()) // When the total score was last calculated

  // Business system
  unlockedBusinessLevel Int @default(0) // Max business level ever owned; 0 = can only create level 1

  // Business bank accounts
  bankAccounts BankAccount[]

  // Business ratings
  businessRatings BusinessRating[]

  @@index([aura])
  @@index([money])
  @@index([referredById])
  @@index([totalScore])
  @@index([overallRank])
}

model RegistrationReview {
  id                    String   @id @default(uuid())
  registrationUserId    String   @unique
  username              String
  firstName             String?
  schoolLevel           String?
  classLetter           String?
  email                 String
  motivationMessage     String?
  registrationCreatedAt DateTime
  status                String
  reviewedAt            DateTime @default(now())
  reviewedById          String?
  importedFromLegacy    Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  reviewedBy User? @relation("RegistrationReviewReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, reviewedAt])
  @@index([reviewedAt])
}

// Item Model
// type: "CONSUMABLE" | "COSMETIC" | "UPGRADE" | "GIFT"
model Item {
  id          String    @id @default(uuid())
  name        String
  description String
  type        String // CONSUMABLE, COSMETIC, UPGRADE, or GIFT
  price       Int
  imageUrl    String?
  effect      String? // JSON string describing the effect
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  userItems            UserItem[]
  marketplaceListings  MarketplaceListing[]
  clanItems            ClanOwnedItem[]
  clanEventRewardTiers ClanEventRewardTier[]
  receivedAsGifts      Gift[]                @relation("GiftedItem")
}

// User Inventory
model UserItem {
  id         String   @id @default(uuid())
  userId     String
  itemId     String
  quantity   Int      @default(1)
  acquiredAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model MarketplaceListing {
  id          String    @id @default(uuid())
  sellerId    String
  itemId      String
  quantity    Int
  unitPrice   Int
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  soldAt      DateTime?
  cancelledAt DateTime?

  seller User @relation("MarketplaceListingSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  item   Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([sellerId, status])
  @@index([itemId])
}

// Transfer/Trade Model
model Transfer {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  auraAmount  Int      @default(0)
  moneyAmount Int      @default(0)
  isGift      Boolean  @default(false) // True if from daily gift allowance
  message     String? // Optional message (max 20 words)
  createdAt   DateTime @default(now())

  sender   User @relation("SentTransfers", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedTransfers", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
}

// Game Statistics
model GameStats {
  id          String @id @default(uuid())
  userId      String
  gameType    String // "doodle_jump", "casino"
  wins        Int    @default(0)
  losses      Int    @default(0)
  highScore   Float  @default(0)
  totalPlayed Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType])
}

model GoyaveSave {
  id        String   @id @default(uuid())
  userId    String   @unique
  saveData  String // JSON blob of SaveState
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClashVillage {
  id                  String    @id @default(uuid())
  userId              String    @unique
  townHallLevel       Int       @default(1)
  moneyInStorage      Int       @default(0)
  trophies            Int       @default(100)
  shieldUntil         DateTime?
  attackCooldownUntil DateTime?
  layoutJson          String    @default("[]")
  buildingsJson       String    @default("[]")
  troopsJson          String    @default("[]")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities ClashActivity[]

  @@index([trophies])
  @@index([moneyInStorage])
}

model ClashBattle {
  id                    String   @id @default(uuid())
  attackerUserId        String
  defenderUserId        String
  destructionPercent    Int
  moneyStolen           Int      @default(0)
  trophiesDeltaAttacker Int      @default(0)
  trophiesDeltaDefender Int      @default(0)
  resultJson            String
  createdAt             DateTime @default(now())

  attacker User @relation("ClashBattleAttacker", fields: [attackerUserId], references: [id], onDelete: Cascade)
  defender User @relation("ClashBattleDefender", fields: [defenderUserId], references: [id], onDelete: Cascade)

  @@index([attackerUserId, createdAt])
  @@index([defenderUserId, createdAt])
  @@index([createdAt])
}

model ClashActivity {
  id            String   @id @default(uuid())
  villageId     String
  type          String
  title         String
  detail        String
  deltaMoney    Int      @default(0)
  deltaTrophies Int      @default(0)
  relatedUserId String?
  createdAt     DateTime @default(now())

  village ClashVillage @relation(fields: [villageId], references: [id], onDelete: Cascade)

  @@index([villageId, createdAt])
  @@index([type, createdAt])
}

model DailyRacerRun {
  id        String   @id @default(uuid())
  userId    String
  trackDate DateTime
  lapTimeMs Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trackDate, lapTimeMs])
  @@index([trackDate, userId])
  @@index([userId, createdAt])
}

model GameScoreHistory {
  id        String   @id @default(uuid())
  userId    String
  gameType  String
  score     Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gameType, createdAt])
  @@index([userId, gameType, createdAt])
}

// Party System
model Party {
  id           String   @id @default(uuid())
  name         String?
  isPublic     Boolean  @default(false)
  maxSize      Int      @default(8)
  createdAt    DateTime @default(now())
  lastActivity DateTime @default(now())

  members       PartyMember[]
  partyMessages PartyMessage[]
}

model PartyMember {
  id       String   @id @default(uuid())
  partyId  String
  userId   String
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@unique([userId]) // User can only be in one party at a time
}

model PartyMessage {
  id        String   @id @default(uuid())
  partyId   String
  userId    String
  message   String
  createdAt DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([partyId, createdAt])
  @@index([userId, createdAt])
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId, createdAt])
  @@index([followingId, createdAt])
}

model Business {
  id                    String    @id @default(uuid())
  ownerId               String
  name                  String
  typeKey               String
  description           String?
  logoUrl               String?
  location              String?
  verified              Boolean   @default(false)
  hiring                Boolean   @default(true)
  startingCapital       Int
  treasuryMoney         Int       @default(0)
  monthlyRevenue        Int       @default(0)
  monthlyExpenses       Int       @default(0)
  satisfaction          Int       @default(70)
  livretEpargneUnlocked Boolean   @default(false)
  loanInterestRate      Float     @default(4.0)
  transferFeeRate       Float     @default(2.0)
  lastBankRevenueDate   String?
  formationUrl          String?
  formationPrice        Int       @default(500)
  npcLastCollectedAt    DateTime? // For lemonade/epicerie NPC collect cooldown
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  owner                User                          @relation("BusinessOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members              BusinessMember[]
  invitations          BusinessInvitation[]
  loans                BusinessLoan[]
  investments          BusinessInvestment[]
  shareholders         BusinessShareholder[]
  shareholderProposals BusinessShareProposal[]
  buyoutOffers         BusinessBuyoutOffer[]
  transferHistory      BusinessTransferTransaction[]
  startupProducts      BusinessStartupProduct[]
  bankAccounts         BankAccount[]
  transactions         BusinessTransaction[]
  ratings              BusinessRating[]
  formationProducts    FormationProduct[]

  @@index([ownerId])
  @@index([typeKey, createdAt])
  @@index([hiring])
}

model FormationProduct {
  id          String   @id @default(uuid())
  businessId  String
  title       String
  description String?
  price       Int      @default(500)
  url         String
  imageUrl    String?
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model BusinessRating {
  id         String   @id @default(uuid())
  businessId String
  userId     String
  rating     Int // 1-5
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId])
}

model BusinessMember {
  id         String   @id @default(uuid())
  businessId String
  userId     String
  role       String
  status     String   @default("ACTIVE")
  salary     Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([userId, status])
}

model BusinessInvitation {
  id          String    @id @default(uuid())
  businessId  String
  inviterId   String
  inviteeId   String
  role        String
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  respondedAt DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  inviter  User     @relation("BusinessInvitationSender", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee  User     @relation("BusinessInvitationRecipient", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@unique([businessId, inviteeId])
  @@index([inviteeId, status])
  @@index([businessId, status])
}

model BusinessLoan {
  id           String    @id @default(uuid())
  businessId   String
  borrowerId   String
  amount       Int
  termMonths   Int
  interestRate Float
  status       String    @default("PENDING")
  repaidAmount Int       @default(0)
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  borrower User     @relation(fields: [borrowerId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([borrowerId, status])
}

model BusinessInvestment {
  id                String   @id @default(uuid())
  businessId        String
  investorId        String
  amount            Int
  riskLevel         String
  expectedReturnMin Int
  expectedReturnMax Int
  createdAt         DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  investor User     @relation(fields: [investorId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([investorId, createdAt])
}

model BusinessShareholder {
  id             String   @id @default(uuid())
  businessId     String
  userId         String
  sharePercent   Float
  investedAmount Int      @default(0)
  averagePrice   Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId])
  @@index([businessId, sharePercent])
  @@index([userId, createdAt])
}

model BusinessShareProposal {
  id              String    @id @default(uuid())
  businessId      String
  investorId      String
  ownerId         String
  sharePercent    Float
  amount          Int
  suggestedAmount Int
  message         String?
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  decidedAt       DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  investor User     @relation("BusinessShareProposalInvestor", fields: [investorId], references: [id], onDelete: Cascade)
  owner    User     @relation("BusinessShareProposalOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([investorId, status])
  @@index([ownerId, status])
}

model BusinessBuyoutOffer {
  id         String    @id @default(uuid())
  businessId String
  bidderId   String
  ownerId    String
  amount     Int
  message    String?
  status     String    @default("PENDING")
  createdAt  DateTime  @default(now())
  decidedAt  DateTime?

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bidder   User     @relation("BuyoutBidder", fields: [bidderId], references: [id], onDelete: Cascade)
  owner    User     @relation("BusinessBuyoutOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([bidderId])
  @@index([ownerId, status])
}

model BusinessTransferTransaction {
  id          String   @id @default(uuid())
  businessId  String
  senderId    String
  recipientId String
  amount      Int
  fee         Int
  feeRate     Float
  createdAt   DateTime @default(now())

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sender    User     @relation("BusinessTransferSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User     @relation("BusinessTransferRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
}

model BusinessStartupProduct {
  id                  String    @id @default(uuid())
  businessId          String
  slotIndex           Int
  name                String
  deployedLevel       Int       @default(0)
  activeResearchLevel Int?
  researchStartedAt   DateTime?
  researchEndsAt      DateTime?
  researchCost        Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, slotIndex])
  @@index([businessId, slotIndex])
}

model UserSkill {
  id        String   @id @default(uuid())
  userId    String
  key       String
  level     Int      @default(1)
  xp        Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model Relationship {
  id              String    @id @default(uuid())
  userAId         String
  userBId         String
  initiatedById   String
  status          String    @default("DATING")
  connectionLevel Int       @default(55)
  coupleBalance   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  marriedAt       DateTime?

  userA             User               @relation("RelationshipUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB             User               @relation("RelationshipUserB", fields: [userBId], references: [id], onDelete: Cascade)
  initiatedBy       User               @relation("RelationshipInitiatedBy", fields: [initiatedById], references: [id], onDelete: Cascade)
  marriageProposals MarriageProposal[]
  divorceProposals  DivorceProposal[]

  @@unique([userAId, userBId])
  @@index([status, connectionLevel])
  @@index([userAId])
  @@index([userBId])
}

model MarriageProposal {
  id             String    @id @default(uuid())
  relationshipId String
  proposerId     String
  recipientId    String
  message        String?
  status         String    @default("PENDING")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  respondedAt    DateTime?

  relationship Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  proposer     User         @relation("MarriageProposalSender", fields: [proposerId], references: [id], onDelete: Cascade)
  recipient    User         @relation("MarriageProposalRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([relationshipId, status])
  @@index([recipientId, status])
}

model DivorceProposal {
  id             String    @id @default(uuid())
  relationshipId String
  proposerId     String
  recipientId    String
  message        String?
  status         String    @default("PENDING")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  respondedAt    DateTime?

  relationship Relationship @relation(fields: [relationshipId], references: [id], onDelete: Cascade)
  proposer     User         @relation("DivorceProposalSender", fields: [proposerId], references: [id], onDelete: Cascade)
  recipient    User         @relation("DivorceProposalRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([relationshipId, status])
  @@index([recipientId, status])
}

model CheatingAccusation {
  id        String   @id @default(uuid())
  accuserId String
  accusedId String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accuser User @relation("AccusationAccuser", fields: [accuserId], references: [id], onDelete: Cascade)
  accused User @relation("AccusationAccused", fields: [accusedId], references: [id], onDelete: Cascade)

  @@index([accusedId, status])
  @@index([accuserId, status])
}

// Clan System
model Clan {
  id            String   @id @default(uuid())
  name          String
  description   String?
  imageUrl      String?
  banner        String?
  isPublic      Boolean  @default(true)
  maxMembers    Int      @default(5)
  warTrophies   Int      @default(1000)
  warWins       Int      @default(0)
  warLosses     Int      @default(0)
  warDraws      Int      @default(0)
  clanBankMoney Int      @default(0)
  level         Int      @default(1)
  ownerId       String
  tagUnlocked   Boolean  @default(false)
  tagText       String?
  tagStyle      String?
  slotUpgraded  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner                 User                       @relation("ClanOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members               ClanMember[]
  joinRequests          ClanJoinRequest[]
  messages              ClanMessage[]
  bankContributions     ClanBankContribution[]
  attackerWars          ClanWar[]                  @relation("ClanWarAttacker")
  defenderWars          ClanWar[]                  @relation("ClanWarDefender")
  wonWars               ClanWar[]                  @relation("ClanWarWinnerClan")
  warDefenses           ClanWarDefense[]
  warAttacks            ClanWarAttack[]            @relation("ClanWarAttackSource")
  warTargets            ClanWarAttack[]            @relation("ClanWarAttackTarget")
  fortifications        ClanWarFortification[]
  warGameLogs           ClanWarGameLog[]
  navalBoards           ClanWarNavalBoard[]
  navalShots            ClanWarNavalShot[]
  pumpUpMessages        ClanPumpUpMessage[]
  ownedItems            ClanOwnedItem[]
  activeEffects         ClanEffect[]
  eventScores           ClanEventClanScore[]
  eventQuestProgresses  ClanEventQuestProgress[]
  eventMiniGameAttempts ClanEventMiniGameAttempt[]
  eventActivities       ClanEventActivity[]

  @@index([isPublic])
  @@index([createdAt])
  @@index([warTrophies])
}

model ClanBankContribution {
  id        String   @id @default(uuid())
  clanId    String
  userId    String
  amount    Int
  createdAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clanId, createdAt])
  @@index([userId, createdAt])
}

model ClanOwnedItem {
  id         String   @id @default(uuid())
  clanId     String
  itemId     String
  quantity   Int      @default(1)
  acquiredAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([clanId, itemId])
  @@index([clanId])
}

model ClanEffect {
  id            String    @id @default(uuid())
  clanId        String
  type          String
  name          String
  description   String?
  value         Int       @default(0)
  durationHours Int       @default(1)
  cooldownHours Int       @default(24)
  activatedAt   DateTime?
  activeUntil   DateTime?
  cooldownUntil DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@unique([clanId, type])
  @@index([clanId, activeUntil])
  @@index([clanId, cooldownUntil])
}

model ClanMember {
  id       String   @id @default(uuid())
  clanId   String
  userId   String
  isLeader Boolean  @default(false)
  joinedAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@unique([userId])
  @@index([clanId])
}

model ClanJoinRequest {
  id        String   @id @default(uuid())
  clanId    String
  userId    String
  createdAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clanId, userId])
  @@index([clanId])
  @@index([userId])
}

model ClanMessage {
  id        String   @id @default(uuid())
  clanId    String
  userId    String
  message   String
  createdAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clanId, createdAt])
  @@index([userId, createdAt])
}

model ClanWar {
  id                     String    @id @default(uuid())
  attackerClanId         String
  defenderClanId         String
  declaredByUserId       String
  winnerClanId           String?
  winnerUserId           String?
  status                 String    @default("PREPARING")
  startsAt               DateTime
  endsAt                 DateTime
  completedAt            DateTime?
  attackerScore          Int       @default(0)
  defenderScore          Int       @default(0)
  attackerTrophiesBefore Int       @default(1000)
  defenderTrophiesBefore Int       @default(1000)
  attackerTrophyChange   Int       @default(0)
  defenderTrophyChange   Int       @default(0)
  targetScore            Int       @default(180)
  winnerRewardMoney      Int       @default(1200)
  loserRewardMoney       Int       @default(300)
  winnerRewardAura       Int       @default(45)
  loserRewardAura        Int       @default(10)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  attackerClan   Clan                   @relation("ClanWarAttacker", fields: [attackerClanId], references: [id], onDelete: Cascade)
  defenderClan   Clan                   @relation("ClanWarDefender", fields: [defenderClanId], references: [id], onDelete: Cascade)
  declaredBy     User                   @relation("ClanWarDeclaredBy", fields: [declaredByUserId], references: [id], onDelete: Cascade)
  winnerClan     Clan?                  @relation("ClanWarWinnerClan", fields: [winnerClanId], references: [id], onDelete: SetNull)
  winnerUser     User?                  @relation("ClanWarWinner", fields: [winnerUserId], references: [id], onDelete: SetNull)
  defenses       ClanWarDefense[]
  attacks        ClanWarAttack[]
  fortifications ClanWarFortification[]
  gameLogs       ClanWarGameLog[]
  navalBoards    ClanWarNavalBoard[]
  navalShots     ClanWarNavalShot[]

  @@index([attackerClanId, status])
  @@index([defenderClanId, status])
  @@index([status, startsAt])
  @@index([status, endsAt])
  @@index([winnerClanId])
}

model ClanWarDefense {
  id            String   @id @default(uuid())
  warId         String
  clanId        String
  type          String
  level         Int      @default(1)
  durability    Int      @default(60)
  maxDurability Int      @default(60)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  war            ClanWar                @relation(fields: [warId], references: [id], onDelete: Cascade)
  clan           Clan                   @relation(fields: [clanId], references: [id], onDelete: Cascade)
  fortifications ClanWarFortification[]

  @@unique([warId, clanId, type])
  @@index([warId, clanId])
}

model ClanWarAttack {
  id                String   @id @default(uuid())
  warId             String
  userId            String
  clanId            String
  targetClanId      String
  attackType        String
  staminaCost       Int      @default(1)
  basePoints        Int
  bonusPoints       Int      @default(0)
  defenseMitigation Int      @default(0)
  structureDamage   Int      @default(0)
  finalPoints       Int
  createdAt         DateTime @default(now())

  war           ClanWar @relation(fields: [warId], references: [id], onDelete: Cascade)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  attackingClan Clan    @relation("ClanWarAttackSource", fields: [clanId], references: [id], onDelete: Cascade)
  targetClan    Clan    @relation("ClanWarAttackTarget", fields: [targetClanId], references: [id], onDelete: Cascade)

  @@index([warId, clanId, createdAt])
  @@index([warId, userId, createdAt])
  @@index([warId, targetClanId, createdAt])
}

model ClanWarFortification {
  id              String   @id @default(uuid())
  warId           String
  defenseId       String
  clanId          String
  userId          String
  levelAdded      Int      @default(0)
  durabilityAdded Int      @default(0)
  createdAt       DateTime @default(now())

  war     ClanWar        @relation(fields: [warId], references: [id], onDelete: Cascade)
  defense ClanWarDefense @relation(fields: [defenseId], references: [id], onDelete: Cascade)
  clan    Clan           @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([warId, clanId, userId])
  @@index([defenseId])
}

// ============================================
// CLAN WAR MINI-GAMES
// ============================================

model ClanWarGameLog {
  id            String   @id @default(uuid())
  warId         String
  userId        String
  clanId        String
  gameType      String // "MEMORY" | "BOMB"
  score         Int      @default(0)
  pointsAwarded Int      @default(0)
  isPractice    Boolean  @default(false)
  playedAt      DateTime @default(now())

  war  ClanWar @relation(fields: [warId], references: [id], onDelete: Cascade)
  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  clan Clan    @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@index([warId, userId, gameType])
  @@index([userId, gameType, playedAt])
}

model ClanWarNavalBoard {
  id     String @id @default(uuid())
  warId  String
  clanId String
  grid   String // JSON: 6x6 array of { type: string|null, hp: number }

  war   ClanWar            @relation(fields: [warId], references: [id], onDelete: Cascade)
  clan  Clan               @relation(fields: [clanId], references: [id], onDelete: Cascade)
  shots ClanWarNavalShot[]

  @@unique([warId, clanId])
  @@index([warId])
}

model ClanWarNavalShot {
  id        String   @id @default(uuid())
  boardId   String
  warId     String
  userId    String
  clanId    String
  x         Int
  y         Int
  isHit     Boolean  @default(false)
  building  String?
  points    Int      @default(0)
  createdAt DateTime @default(now())

  board ClanWarNavalBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  war   ClanWar           @relation(fields: [warId], references: [id], onDelete: Cascade)
  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clan  Clan              @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@unique([boardId, x, y])
  @@index([boardId, userId])
  @@index([warId, clanId])
}

model ClanPumpUpMessage {
  id        String   @id @default(uuid())
  clanId    String
  content   String
  color     String   @default("#ffffff")
  createdAt DateTime @default(now())

  clan Clan @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@index([clanId])
}

model ClanEvent {
  id                   String    @id @default(uuid())
  title                String
  slug                 String    @unique
  description          String?
  bannerUrl            String?
  status               String    @default("DRAFT")
  highlightColor       String?
  rulesSummary         String?
  startsAt             DateTime
  endsAt               DateTime
  createdById          String
  finalizedAt          DateTime?
  rewardsDistributedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  createdBy        User                       @relation("ClanEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  quests           ClanEventQuest[]
  miniGames        ClanEventMiniGame[]
  rewardTiers      ClanEventRewardTier[]
  clanScores       ClanEventClanScore[]
  activities       ClanEventActivity[]
  miniGameAttempts ClanEventMiniGameAttempt[]

  @@index([status, startsAt])
  @@index([status, endsAt])
}

model ClanEventQuest {
  id           String   @id @default(uuid())
  eventId      String
  title        String
  description  String?
  activityType String
  targetValue  Int
  pointsReward Int
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  event      ClanEvent                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  progresses ClanEventQuestProgress[]

  @@index([eventId, sortOrder])
  @@index([eventId, activityType])
}

model ClanEventQuestProgress {
  id           String    @id @default(uuid())
  questId      String
  userId       String
  clanId       String
  currentValue Int       @default(0)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  quest ClanEventQuest @relation(fields: [questId], references: [id], onDelete: Cascade)
  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  clan  Clan           @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@unique([questId, userId])
  @@index([clanId, completedAt])
  @@index([userId, completedAt])
}

model ClanEventMiniGame {
  id                  String   @id @default(uuid())
  eventId             String
  title               String
  description         String?
  type                String
  instructions        String?
  scoreMultiplier     Float    @default(1)
  flatPointsBonus     Int      @default(0)
  maxPointsPerAttempt Int      @default(100)
  maxAttemptsPerUser  Int?
  cooldownMinutes     Int      @default(0)
  sortOrder           Int      @default(0)
  isActive            Boolean  @default(true)
  configJson          String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  event    ClanEvent                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attempts ClanEventMiniGameAttempt[]

  @@index([eventId, sortOrder])
  @@index([eventId, type])
}

model ClanEventMiniGameAttempt {
  id            String   @id @default(uuid())
  eventId       String
  miniGameId    String
  userId        String
  clanId        String
  rawScore      Int
  pointsAwarded Int      @default(0)
  createdAt     DateTime @default(now())

  event    ClanEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  miniGame ClanEventMiniGame @relation(fields: [miniGameId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clan     Clan              @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@index([eventId, clanId, createdAt])
  @@index([miniGameId, userId, createdAt])
}

model ClanEventRewardTier {
  id          String   @id @default(uuid())
  eventId     String
  title       String
  minRank     Int
  maxRank     Int
  moneyReward Int      @default(0)
  auraReward  Int      @default(0)
  itemId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  event ClanEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  item  Item?     @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([eventId, minRank, maxRank])
}

model ClanEventClanScore {
  id          String   @id @default(uuid())
  eventId     String
  clanId      String
  totalPoints Int      @default(0)
  rank        Int?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  event ClanEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  clan  Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)

  @@unique([eventId, clanId])
  @@index([eventId, totalPoints])
}

model ClanEventActivity {
  id         String   @id @default(uuid())
  eventId    String
  clanId     String
  userId     String?
  sourceType String
  label      String
  points     Int      @default(0)
  sourceId   String?
  metadata   String?
  createdAt  DateTime @default(now())

  event ClanEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  clan  Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade)
  user  User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventId, createdAt])
  @@index([eventId, clanId, createdAt])
}

// Chat Messages
model ChatMessage {
  id        String    @id @default(uuid())
  userId    String?
  type      String    @default("user")
  message   String
  imageUrl  String?
  replyToId String?
  pinned    Boolean   @default(false)
  pinnedAt  DateTime?
  createdAt DateTime  @default(now())

  user      User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo   ChatMessage?   @relation("ChatMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[]  @relation("ChatMessageReply")
  reactions ChatReaction[]

  @@index([createdAt])
}

model ChatReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

// Season System
model Season {
  id        String   @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)

  @@index([isActive])
}

// Aura Coin Price History
model AuraCoinPrice {
  id        String   @id @default(uuid())
  price     Float
  volume    Float    @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Aura Coin Transaction
model AuraCoinTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String // "BUY" or "SELL"
  coinAmount  Float
  moneyAmount Int
  price       Float
  fee         Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// Aura Coin Position (Leveraged Trading)
model AuraCoinPosition {
  id           String    @id @default(uuid())
  userId       String
  type         String // "LONG" or "SHORT"
  leverage     Int // 1 to 10
  entryPrice   Float // Price when position was opened
  coinAmount   Float // Notional value in coins
  marginAmount Int // Collateral deposited (money)
  isOpen       Boolean   @default(true)
  closedAt     DateTime?
  exitPrice    Float? // Price when position was closed
  pnl          Int? // Profit/Loss when closed
  liquidated   Boolean   @default(false)
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isOpen])
  @@index([createdAt])
}

// Bug Report
model BugReport {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String
  images      String? // JSON array of image URLs: ["url1", "url2"]
  status      String    @default("PENDING") // PENDING, DONE
  adminReply  String? // Admin's response to the bug report
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
}

// Suggestion
model Suggestion {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String
  imageUrl    String?
  status      String    @default("PENDING") // PENDING, DONE
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?

  user     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes    SuggestionVote[]
  comments SuggestionComment[]
  ratings  SuggestionRating[]

  @@index([status])
  @@index([createdAt])
}

// Suggestion Comment
model SuggestionComment {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  content      String
  createdAt    DateTime @default(now())

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([suggestionId])
  @@index([createdAt])
}

// Suggestion Vote
model SuggestionVote {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  value        Int // 1 for upvote, -1 for downvote
  createdAt    DateTime @default(now())

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

// Suggestion Rating
model SuggestionRating {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  rating       Int // 1-10
  createdAt    DateTime @default(now())

  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

// Bomb Party Prompts (precomputed)
model BombPartyPrompt {
  id        String @id @default(uuid())
  prompt    String @unique // e.g., "TH", "ING", "QU"
  wordCount Int // precomputed count of valid words
  length    Int    @default(2) // prompt length (2 or 3)

  @@index([wordCount])
  @@index([length])
  @@index([length, wordCount])
}

// Game Settings (configurable values for admin panel)
model GameSettings {
  id        String   @id @default(uuid())
  key       String   @unique // e.g., "bombparty_wpp_easy", "bombparty_wpp_medium"
  value     String // stored as string, parsed as needed
  updatedAt DateTime @updatedAt
}

// Tax Brackets (configurable by admin — highest qualifying bracket applies)
model TaxBracket {
  id        String   @id @default(uuid())
  threshold Int // Minimum money to enter this bracket (e.g. 10000)
  rate      Float // Tax rate as percentage (e.g. 1.0 = 1%)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threshold])
}

// Bomb Party Player Stats
model BombPartyStats {
  id          String  @id @default(uuid())
  userId      String  @unique
  wins        Int     @default(0)
  losses      Int     @default(0)
  totalPlayed Int     @default(0)
  wordsTyped  Int     @default(0)
  longestWord String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Ban System
model Ban {
  id        String    @id @default(uuid())
  userId    String
  bannedBy  String // Admin user ID who issued the ban
  reason    String
  type      String // "TEMPORARY" or "PERMANENT"
  expiresAt DateTime? // Null for permanent bans
  createdAt DateTime  @default(now())
  isActive  Boolean   @default(true)

  user    User        @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  admin   User        @relation("BanIssuer", fields: [bannedBy], references: [id], onDelete: Cascade)
  appeals BanAppeal[]

  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
}

// Ban Appeal
model BanAppeal {
  id         String    @id @default(uuid())
  userId     String
  banId      String
  message    String
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt  DateTime  @default(now())
  reviewedAt DateTime?
  reviewedBy String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  ban  Ban  @relation(fields: [banId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

// Name Change Request
model NameChangeRequest {
  id                String    @id @default(uuid())
  userId            String
  currentUsername   String
  requestedUsername String
  reason            String?
  status            String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt         DateTime  @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
  @@index([createdAt])
}

// Activity Log
model Log {
  id         String   @id @default(uuid())
  type       String // AUTH, CHAT, GAME, ECONOMY, PARTY, SUGGESTION, MARKETPLACE, ADMIN, BAN
  action     String // login, logout, register, message, game_complete, transfer, etc.
  userId     String? // User who performed the action (nullable for system events)
  username   String? // Cached username for display
  targetId   String? // Target user/entity ID (for transfers, bans, etc.)
  targetName String? // Cached target name for display
  details    String? // JSON string with additional details
  metadata   String? // JSON string with extra metadata (amounts, scores, etc.)
  ipAddress  String? // IP address if available
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

// Polymarket System
model PolymarketSuggestion {
  id               String    @id @default(uuid())
  userId           String
  title            String
  description      String
  imageUrl         String?
  eventDate        DateTime? // Date de réalisation de l’événement
  suggestedYesOdds Float? // Cote suggérée pour "Oui"
  suggestedNoOdds  Float? // Cote suggérée pour "Non"
  optionsConfig    String? // JSON: [{key,label,color,odds},...] — null = legacy YES/NO
  status           String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt        DateTime  @default(now())
  reviewedAt       DateTime?
  reviewedBy       String? // Admin ID who reviewed

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event PolymarketEvent? // If approved and converted to event

  @@index([status])
  @@index([createdAt])
  @@index([userId])
}

model PolymarketEvent {
  id            String    @id @default(uuid())
  suggestionId  String?   @unique // If created from suggestion
  title         String
  description   String
  imageUrl      String?
  eventDate     DateTime // Date de réalisation de l'événement
  yesOdds       Float // Cote pour "Oui" (ex: 1.5 = mise * 1.5 si gagnant)
  noOdds        Float // Cote pour "Non" (ex: 2.0 = mise * 2.0 si gagnant)
  optionsConfig String? // JSON: [{key,label,color,odds},...] — null = legacy YES/NO
  status        String    @default("OPEN") // OPEN, CLOSED, RESOLVED
  resolution    String? // "YES" or "NO" when resolved
  resolvedAt    DateTime?
  resolvedBy    String? // Admin ID who resolved
  createdAt     DateTime  @default(now())
  closedAt      DateTime? // When betting closed (before event date)

  suggestion PolymarketSuggestion? @relation(fields: [suggestionId], references: [id], onDelete: SetNull)
  bets       PolymarketBet[]

  @@index([status])
  @@index([eventDate])
  @@index([createdAt])
}

model PolymarketBet {
  id         String   @id @default(uuid())
  userId     String
  eventId    String
  prediction String // "YES" or "NO"
  amount     Int // Mise en money
  payout     BigInt? // Gains calculés après résolution (null si perdu)
  createdAt  DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  event PolymarketEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId]) // Un seul pari par utilisateur par événement
  @@index([userId])
  @@index([eventId])
  @@index([createdAt])
}

// ============================================
// DAILY QUESTS SYSTEM
// ============================================

// Daily Quest Template (10 quests generated each day)
model DailyQuest {
  id          String   @id @default(uuid())
  questType   String // "JOIN_PARTIES", "DOODLE_JUMP_SCORE", "GAME_2048_SCORE", "FLAPPY_BIRD_SCORE", "BOMB_PARTY_PLAYS", "POKER_PLAYS", "PETIT_BAC_PLAYS", "BATTLESHIP_PLAYS", "WIN_GAMES", "PLAY_GAMES"
  title       String
  description String
  targetValue Int // Target value (e.g., 3 parties, 1000 score)
  moneyReward Int // Money reward
  auraReward  Int // Aura reward
  questDate   DateTime @default(now()) // Date of the quest (used to group quests by day)
  createdAt   DateTime @default(now())

  userSelections UserDailyQuest[]

  @@index([questDate])
  @@index([questType])
}

// User's selected daily quests (max 3 per day)
model UserDailyQuest {
  id          String    @id @default(uuid())
  userId      String
  questId     String
  questDate   DateTime // Date of the quest
  selectedAt  DateTime  @default(now())
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  isClaimed   Boolean   @default(false)
  claimedAt   DateTime?

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest    DailyQuest         @relation(fields: [questId], references: [id], onDelete: Cascade)
  progress UserQuestProgress?

  @@unique([userId, questId, questDate])
  @@index([userId])
  @@index([questId])
  @@index([questDate])
  @@index([isCompleted])
}

// User's progress on their selected quests
model UserQuestProgress {
  id           String   @id @default(uuid())
  userQuestId  String   @unique
  currentValue Int      @default(0) // Current progress value
  lastUpdated  DateTime @default(now())

  userQuest UserDailyQuest @relation(fields: [userQuestId], references: [id], onDelete: Cascade)

  @@index([userQuestId])
}

// ============================================
// GIFT / PRESENT SYSTEM
// ============================================

// Admin-defined gift templates (items that can be included in gifts)
model GiftTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  price       Int // Cost in money to include this in a gift
  createdAt   DateTime @default(now())

  giftItems GiftItem[]
}

// A gift sent from one user to another
model Gift {
  id           String    @id @default(uuid())
  senderId     String
  receiverId   String
  message      String? // Custom message from the gifter
  moneyAmount  Int       @default(0) // Money included (max 1000)
  auraAmount   Int       @default(0) // Aura included in the gift
  giftedItemId String? // Item.id when a shop GIFT-type item is sent
  isOpened     Boolean   @default(false)
  openedAt     DateTime?
  createdAt    DateTime  @default(now())

  sender     User       @relation("SentGifts", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User       @relation("ReceivedGifts", fields: [receiverId], references: [id], onDelete: Cascade)
  giftedItem Item?      @relation("GiftedItem", fields: [giftedItemId], references: [id], onDelete: SetNull)
  items      GiftItem[]

  @@index([senderId])
  @@index([receiverId])
  @@index([isOpened])
  @@index([createdAt])
  @@index([giftedItemId])
}

// Items included in a gift (references GiftTemplate)
model GiftItem {
  id             String @id @default(uuid())
  giftId         String
  giftTemplateId String

  gift         Gift         @relation(fields: [giftId], references: [id], onDelete: Cascade)
  giftTemplate GiftTemplate @relation(fields: [giftTemplateId], references: [id], onDelete: Cascade)

  @@index([giftId])
  @@index([giftTemplateId])
}

// Online User Snapshot (for activity graphs)
model OnlineSnapshot {
  id        String   @id @default(uuid())
  count     Int // Number of online users at this moment
  usernames String   @default("[]") // JSON: [{userId, username}] captured at snapshot time
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Update Popup System
model UpdatePopup {
  id            String   @id @default(uuid())
  title         String
  summary       String? // Optional short subtitle/summary
  message       String
  imageUrl      String?
  type          String   @default("UPDATE") // "UPDATE" | "CLAN_PROMPT"
  audience      String   @default("ALL") // "ALL" | "NO_CLAN" | "SELECTED_USERS"
  targetUserIds String   @default("[]") // JSON array of user IDs for SELECTED_USERS
  releaseDate   DateTime @default(now())
  isPublished   Boolean  @default(true)
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy User                  @relation("UpdatePopupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  views     UserUpdatePopupView[]

  @@index([isPublished, releaseDate])
  @@index([createdAt])
}

model UserUpdatePopupView {
  id       String   @id @default(uuid())
  userId   String
  popupId  String
  viewedAt DateTime @default(now())

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  popup UpdatePopup @relation(fields: [popupId], references: [id], onDelete: Cascade)

  @@unique([userId, popupId])
  @@index([userId, viewedAt])
}

// ============================================
// NOTIFICATION / INBOX SYSTEM
// ============================================

// Notification types (extensible via the `type` string field):
//   AURA_RECEIVED, MONEY_RECEIVED, GIFT_RECEIVED, ITEM_RECEIVED,
//   CLAN_INVITE, CLAN_JOIN_REQUEST, CLAN_JOIN_ACCEPTED, CLAN_JOIN_REJECTED,
//   QUEST_COMPLETED, POLYMARKET_WIN, POLYMARKET_LOSS,
//   PARTY_INVITE, SYSTEM, ADMIN
model Notification {
  id         String    @id @default(uuid())
  userId     String // Recipient
  type       String // Notification type (see above)
  title      String // Short title
  body       String // Longer description
  data       String? // JSON string for flexible extra payload (amounts, senderIds, etc.)
  link       String? // Optional front-end route to navigate to on click
  icon       String? // Optional icon key (maps to a Lucide icon name on frontend)
  isRead     Boolean   @default(false)
  readAt     DateTime?
  isArchived Boolean   @default(false)
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, isArchived])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ============================================
// BADGE SYSTEM
// ============================================

model Badge {
  id          String  @id @default(uuid())
  name        String
  description String
  howToObtain String?

  // Visual customization
  backgroundType     String  @default("solid") // "solid" | "gradient" | "image"
  backgroundColor    String  @default("#374151")
  backgroundGradient String? // JSON: {"from":"#hex","to":"#hex","direction":"to right"}
  backgroundImage    String? // URL for image background
  icon               String  @default("⭐") // emoji displayed in center
  iconColor          String  @default("#ffffff")
  borderColor        String  @default("#6b7280")

  // Metadata
  category         String  @default("special") // "leaderboard" | "achievement" | "special" | "admin"
  rarity           String  @default("common") // "common" | "uncommon" | "rare" | "epic" | "legendary"
  isAutomatic      Boolean @default(false) // Auto-assigned based on conditions
  autoConditionKey String? // e.g. "TOP_1_AURA", "TOP_5_MONEY", "GAME_HIGHSCORE_DOODLE_JUMP"
  isActive         Boolean @default(true)
  isHidden         Boolean @default(false) // Hidden achievements show as ??? on profiles

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  createdBy       User?               @relation("BadgeCreator", fields: [createdById], references: [id], onDelete: SetNull)
  userBadges      UserBadge[]
  equippedBySlot1 User[]              @relation("UserEquippedBadge1")
  equippedBySlot2 User[]              @relation("UserEquippedBadge2")
  customRequest   CustomBadgeRequest?

  @@index([category])
  @@index([isAutomatic])
  @@index([autoConditionKey])
  @@index([isActive])
}

model UserBadge {
  id             String   @id @default(uuid())
  userId         String
  badgeId        String
  obtainedAt     DateTime @default(now())
  obtainedReason String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// ============================================
// ADMIN WARNING SYSTEM
// ============================================

// Admin warnings that display as mandatory popup modals
model AdminWarning {
  id             String    @id @default(uuid())
  userId         String // User receiving the warning
  issuedById     String // Admin who issued the warning
  message        String // Warning message content
  severity       String    @default("MEDIUM") // LOW, MEDIUM, HIGH
  isAcknowledged Boolean   @default(false)
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  user     User @relation("WarningsReceived", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy User @relation("WarningsIssued", fields: [issuedById], references: [id], onDelete: Cascade)

  @@index([userId, isAcknowledged])
  @@index([createdAt])
}

// Custom Badge Requests (user-submitted, admin-reviewed)
model CustomBadgeRequest {
  id              String  @id @default(uuid())
  userId          String
  status          String  @default("pending") // "pending" | "approved" | "rejected"
  name            String
  description     String
  icon            String  @default("⭐")
  backgroundColor String  @default("#374151")
  borderColor     String  @default("#6b7280")
  rarity          String  @default("common")
  adminNote       String?
  badgeId         String? @unique // Set on approval to the created Badge id
  pricePaid       Int     @default(0) // Refunded on rejection

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge? @relation(fields: [badgeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

// Support / Messaging system (user ↔ admin)
model SupportMessage {
  id        String   @id @default(uuid())
  userId    String // The user this thread belongs to
  images    String? // JSON array of image URLs: ["url1", "url2"]
  body      String
  fromAdmin Boolean  @default(false) // true = sent by an admin
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation("UserSupportMessages", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ============================================
// POLYTRACK RECORDS
// ============================================

// Stores per-track personal bests submitted manually by users after playing.
// trackNumber: 1-14 matching the tracks in the embedded game.
// timeMs: lap time in milliseconds (lower = better).
model PolytrackRecord {
  id          String   @id @default(uuid())
  userId      String
  trackNumber Int // 1-14
  timeMs      Int // Lap time in milliseconds
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Only one personal best per user per track (upsert replaces if lower)
  @@unique([userId, trackNumber])
  @@index([trackNumber, timeMs])
  @@index([userId])
}

// ============================================
// UPDATES / CHANGELOG
// ============================================
model UpdateEntry {
  id        String       @id @default(uuid())
  date      String // ISO date string e.g. "2026-03-29"
  title     String
  summary   String
  createdAt DateTime     @default(now())
  items     UpdateItem[]

  @@index([date])
}

model UpdateItem {
  id        String      @id @default(uuid())
  entryId   String
  entry     UpdateEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  category  String // BIG_FEATURE | SMALL_FEATURE | BUG_FIX
  text      String
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([entryId])
}

model BankAccount {
  id          String   @id @default(uuid())
  businessId  String
  userId      String
  balance     Int      @default(0)
  accountType String   @default("COURANT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([businessId, userId, accountType])
  @@index([userId])
  @@index([businessId])
}

model BusinessTransaction {
  id         String   @id @default(uuid())
  businessId String
  type       String
  amount     Int
  label      String
  actorId    String?
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, createdAt])
}
