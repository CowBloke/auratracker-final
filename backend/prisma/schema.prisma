generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User Model
model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  aura          BigInt    @default(0)
  money         Int       @default(1000)
  auraCoinBalance Float   @default(0)         // Aura Coin balance for trading game
  isAdmin       Boolean   @default(false)
  isApproved    Boolean   @default(false)     // Account must be approved by admin before login
  dailyAuraGiven Int      @default(0)        // Aura given today
  dailyAuraLimit Int      @default(50)       // Personal daily aura limit (default 50)
  lastDailyReset DateTime @default(now())    // When daily allowance was last reset
  usernameColor String?                       // Custom username color for chat (hex)
  profilePicture String?                      // Custom profile picture URL for chat
  bio           String?                       // User bio/description
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  ownedItems        UserItem[]
  sentTransfers     Transfer[] @relation("SentTransfers")
  receivedTransfers Transfer[] @relation("ReceivedTransfers")
  gameStats         GameStats[]
  partyMemberships  PartyMember[]
  sentMessages      ChatMessage[]
  chatReactions     ChatReaction[]
  clashBase         ClashBase?
  attacksMade       Attack[]   @relation("Attacker")
  attacksReceived   Attack[]   @relation("Defender")
  auraCoinTransactions AuraCoinTransaction[]
  bugReports        BugReport[]
  suggestions       Suggestion[]
  suggestionVotes   SuggestionVote[]
  suggestionComments SuggestionComment[]
  suggestionRatings SuggestionRating[]
  bombPartyStats    BombPartyStats?
  bansReceived      Ban[]              @relation("BannedUser")
  bansIssued        Ban[]              @relation("BanIssuer")
  userBadges        UserBadge[]

  @@index([aura])
  @@index([money])
}

// Badge System
model Badge {
  id        String    @id @default(uuid())
  name      String
  color     String
  createdAt DateTime  @default(now())

  users     UserBadge[]
}

model UserBadge {
  id         String    @id @default(uuid())
  userId     String
  badgeId    String
  assignedAt DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// Item Model
// type: "CONSUMABLE" | "COSMETIC" | "UPGRADE"
model Item {
  id          String    @id @default(uuid())
  name        String
  description String
  type        String    // CONSUMABLE, COSMETIC, or UPGRADE
  price       Int
  imageUrl    String?
  effect      String?   // JSON string describing the effect
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  
  userItems   UserItem[]
}

// User Inventory
model UserItem {
  id          String    @id @default(uuid())
  userId      String
  itemId      String
  quantity    Int       @default(1)
  acquiredAt  DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  item        Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  @@unique([userId, itemId])
}

// Transfer/Trade Model
model Transfer {
  id          String    @id @default(uuid())
  senderId    String
  receiverId  String
  auraAmount  Int       @default(0)
  moneyAmount Int       @default(0)
  isGift      Boolean   @default(false)  // True if from daily gift allowance
  message     String?   // Optional message (max 20 words)
  createdAt   DateTime  @default(now())
  
  sender      User      @relation("SentTransfers", fields: [senderId], references: [id], onDelete: Cascade)
  receiver    User      @relation("ReceivedTransfers", fields: [receiverId], references: [id], onDelete: Cascade)
  
  @@index([senderId])
  @@index([receiverId])
}

// Game Statistics
model GameStats {
  id          String    @id @default(uuid())
  userId      String
  gameType    String    // "doodle_jump", "casino"
  wins        Int       @default(0)
  losses      Int       @default(0)
  highScore   Int       @default(0)
  totalPlayed Int       @default(0)
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, gameType])
}

// Party System
model Party {
  id           String        @id @default(uuid())
  name         String?
  isPublic     Boolean       @default(false)
  maxSize      Int           @default(8)
  createdAt    DateTime      @default(now())
  lastActivity DateTime      @default(now())
  
  members      PartyMember[]
}

model PartyMember {
  id        String   @id @default(uuid())
  partyId   String
  userId    String
  isLeader  Boolean  @default(false)
  joinedAt  DateTime @default(now())
  
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([partyId, userId])
  @@unique([userId]) // User can only be in one party at a time
}

// Chat Messages
model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  message   String
  replyToId String?
  pinned    Boolean  @default(false)
  pinnedAt  DateTime?
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo   ChatMessage? @relation("ChatMessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[] @relation("ChatMessageReply")
  reactions ChatReaction[]
  
  @@index([createdAt])
}

model ChatReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

// Season System
model Season {
  id          String    @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean   @default(true)
  
  @@index([isActive])
}

// Clash of Clans Base
model ClashBase {
  id              String    @id @default(uuid())
  userId          String    @unique
  baseLayout      String    // JSON string storing building positions/levels
  defenseRating   Int       @default(100)
  trophies        Int       @default(0)
  lastAttackedAt  DateTime?
  shieldUntil     DateTime?
  attackCooldown  DateTime? // When user can attack again
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([defenseRating])
  @@index([trophies])
}

// Attack Log
model Attack {
  id            String    @id @default(uuid())
  attackerId    String
  defenderId    String
  success       Boolean
  starsEarned   Int       @default(0) // 0-3 stars
  destruction   Int       @default(0) // Percentage 0-100
  auraTaken     Int       @default(0)
  moneyTaken    Int       @default(0)
  trophiesWon   Int       @default(0)
  trophiesLost  Int       @default(0)
  replayData    String?   // JSON string for replay
  attackedAt    DateTime  @default(now())
  
  attacker      User      @relation("Attacker", fields: [attackerId], references: [id], onDelete: Cascade)
  defender      User      @relation("Defender", fields: [defenderId], references: [id], onDelete: Cascade)
  
  @@index([attackerId])
  @@index([defenderId])
  @@index([attackedAt])
}

// Aura Coin Price History
model AuraCoinPrice {
  id        String   @id @default(uuid())
  price     Float
  volume    Float    @default(0)
  createdAt DateTime @default(now())
  
  @@index([createdAt])
}

// Aura Coin Transaction
model AuraCoinTransaction {
  id          String   @id @default(uuid())
  userId      String
  type        String   // "BUY" or "SELL"
  coinAmount  Float
  moneyAmount Int
  price       Float
  fee         Int
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([createdAt])
}

// Bug Report
model BugReport {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  status      String   @default("PENDING") // PENDING, DONE
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([status])
  @@index([createdAt])
}

// Suggestion
model Suggestion {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String
  imageUrl    String?
  status      String   @default("PENDING") // PENDING, DONE
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  votes       SuggestionVote[]
  comments    SuggestionComment[]
  ratings     SuggestionRating[]
  
  @@index([status])
  @@index([createdAt])
}

// Suggestion Comment
model SuggestionComment {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  content      String
  createdAt    DateTime @default(now())

  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([suggestionId])
  @@index([createdAt])
}

// Suggestion Vote
model SuggestionVote {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  value        Int      // 1 for upvote, -1 for downvote
  createdAt    DateTime @default(now())

  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

// Suggestion Rating
model SuggestionRating {
  id           String   @id @default(uuid())
  suggestionId String
  userId       String
  rating       Int      // 1-10
  createdAt    DateTime @default(now())

  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@index([suggestionId])
}

// Bomb Party Prompts (precomputed)
model BombPartyPrompt {
  id         String @id @default(uuid())
  prompt     String @unique  // e.g., "TH", "ING", "QU"
  wordCount  Int              // precomputed count of valid words
  difficulty String           // "easy", "medium", "hard"
  length     Int    @default(2) // prompt length (2 or 3)

  @@index([difficulty])
  @@index([wordCount])
  @@index([length])
}

// Game Settings (configurable values for admin panel)
model GameSettings {
  id         String @id @default(uuid())
  key        String @unique  // e.g., "bombparty_wpp_easy", "bombparty_wpp_medium"
  value      String          // stored as string, parsed as needed
  updatedAt  DateTime @updatedAt
}

// Bomb Party Player Stats
model BombPartyStats {
  id           String  @id @default(uuid())
  userId       String  @unique
  wins         Int     @default(0)
  losses       Int     @default(0)
  totalPlayed  Int     @default(0)
  wordsTyped   Int     @default(0)
  longestWord  String?

  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Ban System
model Ban {
  id          String    @id @default(uuid())
  userId      String
  bannedBy    String    // Admin user ID who issued the ban
  reason      String
  type        String    // "TEMPORARY" or "PERMANENT"
  expiresAt   DateTime? // Null for permanent bans
  createdAt   DateTime  @default(now())
  isActive    Boolean   @default(true)

  user        User      @relation("BannedUser", fields: [userId], references: [id], onDelete: Cascade)
  admin       User      @relation("BanIssuer", fields: [bannedBy], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
}

// Activity Log
model Log {
  id          String    @id @default(uuid())
  type        String    // AUTH, CHAT, GAME, ECONOMY, PARTY, SUGGESTION, MARKETPLACE, ADMIN, BAN
  action      String    // login, logout, register, message, game_complete, transfer, etc.
  userId      String?   // User who performed the action (nullable for system events)
  username    String?   // Cached username for display
  targetId    String?   // Target user/entity ID (for transfers, bans, etc.)
  targetName  String?   // Cached target name for display
  details     String?   // JSON string with additional details
  metadata    String?   // JSON string with extra metadata (amounts, scores, etc.)
  ipAddress   String?   // IP address if available
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([action])
  @@index([userId])
  @@index([createdAt])
}
