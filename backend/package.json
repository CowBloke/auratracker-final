{
  "name": "aura-tracker-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Aura Tracker Backend API",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "prisma generate",
    "predev": "prisma generate && prisma db push --skip-generate --accept-data-loss",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "prestart": "prisma generate && prisma db push --skip-generate",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "rankings:recompute": "tsx src/scripts/recomputeOverallClassement.ts",
    "pixel-board:scoring": "tsx src/scripts/pixelBoardScoring.ts",
    "pixel-board:heatmap": "tsx src/scripts/pixelBoardHeatmap.ts",
    "pixel-board:timelapse": "tsx src/scripts/pixelBoardTimelapse.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-bombparty": "tsx prisma/seed-bombparty.ts",
    "db:seed-basic": "tsx prisma/seed-basic.ts",
    "db:seed-badges": "tsx prisma/seed-badges.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@types/nodemailer": "^7.0.11",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "chess.js": "^1.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.1",
    "socket.io": "^4.7.4",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/http-proxy-middleware": "^0.19.3",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.10",
    "@types/uuid": "^9.0.8",
    "@types/web-push": "^3.6.4",
    "prisma": "^7.8.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
