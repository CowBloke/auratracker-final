# Example environment configuration
# Copy this file to .env.local for local overrides

# API URL - automatically set based on environment
# Development: http://localhost:3000
# Production: https://auratracker.xyz
VITE_API_URL=

# Socket.IO URL - automatically set based on environment
# Development: http://localhost:3000
# Production: https://auratracker.xyz
VITE_SOCKET_URL=

# Optional TURN relay settings for AuraVision WebRTC
# Example:
# VITE_AURAVISION_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# VITE_AURAVISION_TURN_USERNAME=my-user
# VITE_AURAVISION_TURN_CREDENTIAL=my-password
VITE_AURAVISION_TURN_URLS=
VITE_AURAVISION_TURN_USERNAME=
VITE_AURAVISION_TURN_CREDENTIAL=
